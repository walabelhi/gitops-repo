apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: expiration-service
  namespace: argocd
spec:
  project: default

  source:
    repoURL: https://github.com/walabelhi/micro-app
    targetRevision: main
    path: expiration/k8s

  destination:
    server: https://kubernetes.default.svc
    namespace: expiration

  syncPolicy:
    automated:
      prune: true
      selfHeal: true
